# .env.local.example
# ─────────────────────────────────────────────────────────────
# Barterkin environment variables
# Copy to .env.local and fill in actual values. NEVER commit .env.local.
# Production/preview values live in Vercel env vars (per-environment scope).
# GitHub Actions secrets hold any CI-only values.
# Repo is PUBLIC — any secret with NEXT_PUBLIC_ prefix is browser-readable.
# ─────────────────────────────────────────────────────────────

# ── Supabase (project: hfdcsickergdcdvejbcw, region: us-east-1) ──

# Public URL — safe in browser, used by browser + server clients
NEXT_PUBLIC_SUPABASE_URL=https://hfdcsickergdcdvejbcw.supabase.co

# Publishable (anon-tier) key — safe in browser; RLS is the security boundary
# If your Supabase project still issues legacy `anon` keys, the same value works;
# rotate to the new `sb_publishable_...` format in Studio when convenient.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service-role key — SERVER ONLY, bypasses RLS entirely. NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# ── Resend (domain: barterkin.com, verified 10/10 mail-tester) ──

# Transactional email API key — server-only
RESEND_API_KEY=

# ── PostHog (project id: 387571, host: US) ──

NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Cloudflare Turnstile (widget: Georgia Barter, managed mode) ──

# Public site key — safe in browser, used by the Turnstile widget script
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key-here

# ── Site ──

# Used to construct absolute URLs (OAuth redirects, email links, canonical tags).
# Phase 1 value: http://localhost:3000 (local) / <preview>.vercel.app (preview)
# Phase 6+: https://barterkin.com (prod)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Phase 5 — Contact Relay + Trust ──

# Resend webhook signing secret — Vercel env var (production + preview scopes)
# Obtain from: Resend Dashboard → Webhooks → Add endpoint → copy signing secret
RESEND_WEBHOOK_SECRET=whsec_replace_with_value_from_resend_dashboard
# Note: RESEND_API_KEY above is used by the Resend webhook handler (app/api/webhooks/resend/route.ts)
# to instantiate the Resend SDK for webhooks.verify() — already present for the test-email route.
# The send-contact Edge Function uses RESEND_API_KEY from SUPABASE secrets (not Vercel env).
# Set via: pnpm supabase secrets set RESEND_API_KEY=re_xxx POSTHOG_API_KEY=phc_xxx EMAIL_FROM='Barterkin <noreply@barterkin.com>' NEXT_PUBLIC_SITE_URL=https://barterkin.com

# ── Phase 8 — Admin Dashboard ──

# Admin account email — server-only, NO NEXT_PUBLIC_ prefix.
# Middleware compares this against claims.email (JWKS-verified top-level claim).
# Production value is set in Vercel env vars — this file is the template only.
ADMIN_EMAIL=barterkin101@gmail.com
